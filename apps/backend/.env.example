# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hr_interview
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=hr_interview

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Storage (S3-compatible)
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=hr-interview-recordings
AWS_S3_ENDPOINT=

# Daily.co
DAILY_API_KEY=your-daily-api-key
DAILY_API_URL=https://api.daily.co/v1

# AI / AgentBase LLM (OpenAI-compatible)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=
# TTS/STT models on AgentBase (model `path` from `aip.sh models list`); leave empty to fall back to direct OpenAI
TTS_MODEL=
STT_MODEL=
# Per-account whisper transcription base URL (from AI Platform console), e.g.
# https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXXX/openai/whisper-large-v3/v1
STT_BASE_URL=
# Gemini prebuilt voice name for /speech/tts (e.g. Zephyr, Kore)
TTS_VOICE=Zephyr

# ElevenLabs TTS (highest-fidelity voice). When ELEVENLABS_API_KEY is set it takes
# priority over AgentBase/OpenAI TTS. Pick a Vietnamese-friendly voice id from your
# ElevenLabs dashboard; model eleven_multilingual_v2 supports Vietnamese.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# Legacy direct OpenAI fallback
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
TTS_PROVIDER=openai
STT_PROVIDER=openai

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3001

# Email (SMTP). Leave SMTP_HOST empty in dev — invites/notifications are logged, not sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HR Interview <no-reply@hr-interview.local>"
# Candidate invitation link expiry, in days
INVITE_EXPIRY_DAYS=7

# Interview agent (orchestrator)
# AGENT_GREETING_TEXT="Xin chào! Tôi là trợ lý phỏng vấn AI..."
# AGENT_CLOSING_TEXT="Cảm ơn bạn đã hoàn thành buổi phỏng vấn..."
AGENT_LANGUAGE=vi

# LiveKit Cloud (preferred video provider; falls back to Daily when unset)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Recording via egress — S3 storage must be PUBLICLY reachable (not local MinIO)
LIVEKIT_EGRESS_S3_BUCKET=
LIVEKIT_EGRESS_S3_REGION=us-east-1
LIVEKIT_EGRESS_S3_ACCESS_KEY=
LIVEKIT_EGRESS_S3_SECRET=
LIVEKIT_EGRESS_S3_ENDPOINT=
