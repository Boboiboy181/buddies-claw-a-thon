# Env file for the AgentBase combined-container deploy.
# Copy to `.env.agentbase` (git-ignored) and fill in real values, then pass it to
# the runtime via:  runtime.sh create ... --env-file .env.agentbase
#
# DO NOT set GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET / GREENNODE_AGENT_IDENTITY /
# GREENNODE_ENDPOINT_URL here — AgentBase injects those automatically.
#
# PORT (8080) and CLIENT_DIST_PATH are baked into Dockerfile.agentbase — no need to set them.

# ── Data stores (must be reachable from the runtime; use the vServer's PRIVATE IP in VPC mode) ──
# Postgres
DATABASE_URL=postgresql://postgres:postgres@10.0.0.10:5432/hr_interview

# Redis
REDIS_HOST=10.0.0.10
REDIS_PORT=6379

# Object storage (S3-compatible). For recordings to work this must be PUBLICLY reachable.
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=hr-interview-recordings
AWS_S3_ENDPOINT=http://10.0.0.10:9000

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── AI / LLM (OpenAI-compatible MaaS) — required for question + report generation ──
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=
# Speech (optional; falls back to direct OpenAI when empty)
TTS_MODEL=
STT_MODEL=
STT_BASE_URL=
TTS_VOICE=Zephyr

# Legacy direct OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── App ──
# FRONTEND_URL is used for the CORS allowlist. In the combined deploy the SPA is
# same-origin, so set this to the AgentBase endpoint URL once you know it.
FRONTEND_URL=https://your-agentbase-endpoint-url
AGENT_LANGUAGE=vi

# ── Video (optional) ──
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co/v1
